<%- include('partials/header', { title: 'Editar Produto' }) %>

<section class="page-heading">
   <p class="eyebrow">Produto #<%= produto.id %></p>
   <h1>Editar Produto</h1>
</section>

<section class="form-panel">
   <form action="/produtos/edit/<%= produto.id %>" method="POST">
      <label for="nome">Nome do Produto:</label>
      <input type="text" id="nome" name="nome" value="<%= produto.nome %>" required>
      
      <label for="descricao">Descricao:</label>
      <textarea id="descricao" name="descricao" required><%= produto.descricao %></textarea>
      
      <label for="preco">Preco:</label>
      <input type="text" id="preco" name="preco" value="<%= formatarPrecoParaInput(produto.preco) %>" inputmode="decimal" required>
      
      <div class="form-actions">
         <button type="submit">Salvar Alteracoes</button>
         <a href="/produtos" class="button-muted">Cancelar</a>
      </div>
   </form>
</section>

<%- include('partials/footer') %>
