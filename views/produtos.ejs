<%- include('partials/header', { title: 'Lista de Produtos' }) %>

<section class="page-heading">
    <p class="eyebrow">Catalogo</p>
    <h1>Produtos</h1>
</section>

<% if (produtos.length === 0) { %>
    <p class="empty-state">Nenhum produto cadastrado ainda.</p>
<% } else { %>
    <div class="table-shell">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Descricao</th>
                    <th>Preco</th>
                    <th>Acoes</th>
                </tr>
            </thead>
            <tbody>
                <% produtos.forEach(produto => { %>
                    <tr>
                        <td><strong>#<%= produto.id %></strong></td>
                        <td><%= produto.nome %></td>
                        <td><%= produto.descricao %></td>
                        <td class="price"><%= formatarPreco(produto.preco) %></td>
                        <td class="actions">
                            <a href="/produtos/edit/<%= produto.id %>" class="button-warning">Editar</a>
                            <a href="/produtos/delete/<%= produto.id %>" class="button-danger" onclick="return confirm('Tem certeza que deseja deletar este produto?');">Deletar</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } %>

<section class="form-panel">
    <h2>Adicionar Novo Produto</h2>
    <form action="/produtos" method="POST">
       <label for="nome">Nome do Produto:</label>
       <input type="text" id="nome" name="nome" placeholder="Digite o nome do produto" required>
       
       <label for="descricao">Descricao:</label>
       <textarea id="descricao" name="descricao" placeholder="Digite uma descricao do produto" required></textarea>
       
       <label for="preco">Preco:</label>
       <input type="text" id="preco" name="preco" placeholder="Ex: 100,00" inputmode="decimal" required>
       
       <button type="submit">Adicionar Produto</button>
    </form>
</section>

<%- include('partials/footer') %>
